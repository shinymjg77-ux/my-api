APP_NAME=Personal API Admin
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api/v1

SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
ENCRYPTION_KEY=replace-with-a-valid-fernet-key
JOB_SHARED_SECRET=replace-with-a-random-string-at-least-32-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=120
ADMIN_COOKIE_NAME=admin_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

