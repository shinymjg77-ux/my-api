ALERT_WEBHOOK_TYPE=discord
ALERT_WEBHOOK_URL=
ALERT_SOURCE=admin.example.com
RELEASE_REPO_URL=https://github.com/shinymjg77-ux/my-api.git
RELEASE_REPO_DIR=/srv/my-api/repo
N8N_PROJECT_DIR=/opt/n8n
N8N_COMPOSE_PATH=/opt/n8n/docker-compose.yml
N8N_ENV_FILE=/etc/my-api/n8n.env
N8N_CONTAINER_NAME=n8n
BACKEND_STABLE_BASE_URL=http://127.0.0.1:9000
BACKEND_UPSTREAM_CONF=/etc/nginx/snippets/my-api-backend-upstream.conf
BACKEND_ACTIVE_SLOT_STATE_PATH=/srv/my-api/state/backend-active-slot
BACKEND_SLOT_ROOT=/srv/my-api/slots
BACKEND_SLOT_ENV_DIR=/etc/my-api/backend-slots
BACKEND_SLOTS=blue,green
FRONTEND_STABLE_BASE_URL=http://127.0.0.1:3100
FRONTEND_UPSTREAM_CONF=/etc/nginx/snippets/my-api-frontend-upstream.conf
FRONTEND_ACTIVE_SLOT_STATE_PATH=/srv/my-api/state/frontend-active-slot
FRONTEND_SLOT_ROOT=/srv/my-api/slots
FRONTEND_SLOT_ENV_DIR=/etc/my-api/frontend-slots
FRONTEND_SLOTS=blue,green

REMOTE_BACKUP_ENABLED=false
REMOTE_BACKUP_ENDPOINT=
REMOTE_BACKUP_BUCKET=
REMOTE_BACKUP_PREFIX=sqlite
AWS_BIN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-seoul-1
